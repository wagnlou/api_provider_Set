#!/usr/bin/env python3
"""cc-api Web UI — Flask server for Claude Code API Provider management."""

import argparse
import configparser
import json
import os
import webbrowser
from threading import Timer

try:
    from flask import Flask, jsonify, request, render_template_string
except ImportError:
    print("Error: flask is required. Install with: pip install flask")
    raise SystemExit(1)

PROFILES_FILE = os.environ.get(
    'CC_API_PROFILES', os.path.expanduser('~/.claude/api_profiles.ini')
)
SETTINGS_FILE = os.environ.get(
    'CC_API_SETTINGS', os.path.expanduser('~/.claude/settings.json')
)

app = Flask(__name__)
app.config['JSON_SORT_KEYS'] = False


# ── File I/O ──────────────────────────────────────────────────────────────────

def _read_profiles():
    cfg = configparser.RawConfigParser()
    cfg.read(PROFILES_FILE)
    return {s: dict(cfg[s]) for s in cfg.sections()}


def _write_profiles(profiles: dict):
    cfg = configparser.RawConfigParser()
    for name, fields in profiles.items():
        cfg[name] = {k: v for k, v in fields.items() if v}
    os.makedirs(os.path.dirname(PROFILES_FILE), exist_ok=True)
    with open(PROFILES_FILE, 'w') as f:
        cfg.write(f)


def _read_settings():
    try:
        with open(SETTINGS_FILE) as f:
            return json.load(f)
    except (FileNotFoundError, json.JSONDecodeError):
        return {}


def _write_settings(cfg: dict):
    with open(SETTINGS_FILE, 'w') as f:
        json.dump(cfg, f, indent=2)
        f.write('\n')


def _mask_key(key: str) -> str:
    if len(key) > 12:
        return key[:8] + '***' + key[-4:]
    return '***' if key else ''


def _get_current_key() -> str:
    return _read_settings().get('env', {}).get('ANTHROPIC_AUTH_TOKEN', '')


# ── API routes ────────────────────────────────────────────────────────────────

@app.route('/api/profiles', methods=['GET'])
def api_get_profiles():
    profiles = _read_profiles()
    current_key = _get_current_key()
    result = []
    for name, fields in profiles.items():
        key = fields.get('api_key', '')
        entry = {
            'name': name,
            'api_key': key,
            'api_key_masked': _mask_key(key),
            'base_url': fields.get('base_url', ''),
            'model': fields.get('model', ''),
            'tier': fields.get('tier', ''),
            'default_haiku': fields.get('default_haiku', ''),
            'default_sonnet': fields.get('default_sonnet', ''),
            'default_opus': fields.get('default_opus', ''),
            'active': (key == current_key and bool(current_key)),
        }
        result.append(entry)
    return jsonify(result)


@app.route('/api/current', methods=['GET'])
def api_get_current():
    cfg = _read_settings()
    env = cfg.get('env', {})
    key = env.get('ANTHROPIC_AUTH_TOKEN', '')
    return jsonify({
        'api_key': key,
        'api_key_masked': _mask_key(key),
        'base_url': env.get('ANTHROPIC_BASE_URL', ''),
        'model': env.get('ANTHROPIC_MODEL', ''),
        'tier': cfg.get('model', ''),
        'default_haiku': env.get('ANTHROPIC_DEFAULT_HAIKU_MODEL', ''),
        'default_sonnet': env.get('ANTHROPIC_DEFAULT_SONNET_MODEL', ''),
        'default_opus': env.get('ANTHROPIC_DEFAULT_OPUS_MODEL', ''),
    })


@app.route('/api/switch/<name>', methods=['POST'])
def api_switch(name):
    profiles = _read_profiles()
    if name not in profiles:
        return jsonify({'error': f"Profile '{name}' not found"}), 404
    p = profiles[name]
    key, url = p.get('api_key', ''), p.get('base_url', '')
    if not key or not url:
        return jsonify({'error': f"Profile '{name}' is incomplete (missing api_key or base_url)"}), 400
    cfg = _read_settings()
    cfg.setdefault('env', {})
    cfg['env']['ANTHROPIC_AUTH_TOKEN'] = key
    cfg['env']['ANTHROPIC_BASE_URL'] = url
    for var in ('ANTHROPIC_MODEL', 'ANTHROPIC_DEFAULT_HAIKU_MODEL',
                'ANTHROPIC_DEFAULT_SONNET_MODEL', 'ANTHROPIC_DEFAULT_OPUS_MODEL'):
        cfg['env'].pop(var, None)
    if p.get('model'):
        cfg['env']['ANTHROPIC_MODEL'] = p['model']
    if p.get('default_haiku'):
        cfg['env']['ANTHROPIC_DEFAULT_HAIKU_MODEL'] = p['default_haiku']
    if p.get('default_sonnet'):
        cfg['env']['ANTHROPIC_DEFAULT_SONNET_MODEL'] = p['default_sonnet']
    if p.get('default_opus'):
        cfg['env']['ANTHROPIC_DEFAULT_OPUS_MODEL'] = p['default_opus']
    if p.get('tier'):
        cfg['model'] = p['tier']
    else:
        cfg.pop('model', None)
    _write_settings(cfg)
    return jsonify({'ok': True, 'switched_to': name})


@app.route('/api/profiles', methods=['POST'])
def api_add_profile():
    data = request.get_json() or {}
    name = data.get('name', '').strip()
    if not name:
        return jsonify({'error': 'name is required'}), 400
    profiles = _read_profiles()
    if name in profiles:
        return jsonify({'error': f"Profile '{name}' already exists"}), 409
    entry = {k: data.get(k, '').strip()
             for k in ('api_key', 'base_url', 'model', 'tier',
                       'default_haiku', 'default_sonnet', 'default_opus')}
    if not entry['api_key'] or not entry['base_url']:
        return jsonify({'error': 'api_key and base_url are required'}), 400
    profiles[name] = entry
    _write_profiles(profiles)
    return jsonify({'ok': True})


@app.route('/api/profiles/<name>', methods=['PUT'])
def api_edit_profile(name):
    profiles = _read_profiles()
    if name not in profiles:
        return jsonify({'error': f"Profile '{name}' not found"}), 404
    data = request.get_json() or {}
    entry = {k: data.get(k, '').strip()
             for k in ('api_key', 'base_url', 'model', 'tier',
                       'default_haiku', 'default_sonnet', 'default_opus')}
    if not entry['api_key'] or not entry['base_url']:
        return jsonify({'error': 'api_key and base_url are required'}), 400
    profiles[name] = entry
    _write_profiles(profiles)
    return jsonify({'ok': True})


@app.route('/api/profiles/<name>', methods=['DELETE'])
def api_delete_profile(name):
    profiles = _read_profiles()
    if name not in profiles:
        return jsonify({'error': f"Profile '{name}' not found"}), 404
    del profiles[name]
    _write_profiles(profiles)
    return jsonify({'ok': True})


@app.route('/api/model', methods=['POST'])
def api_model():
    data = request.get_json() or {}
    cfg = _read_settings()
    cfg.setdefault('env', {})
    if data.get('clear'):
        cfg['env'].pop('ANTHROPIC_MODEL', None)
        _write_settings(cfg)
        return jsonify({'ok': True, 'model': ''})
    model = data.get('model', '').strip()
    if not model:
        return jsonify({'error': 'model is required'}), 400
    cfg['env']['ANTHROPIC_MODEL'] = model
    _write_settings(cfg)
    return jsonify({'ok': True, 'model': model})


@app.route('/api/tier', methods=['POST'])
def api_tier():
    data = request.get_json() or {}
    tier = data.get('tier', '').strip()
    if tier not in ('opus', 'sonnet', 'haiku'):
        return jsonify({'error': 'tier must be opus, sonnet, or haiku'}), 400
    cfg = _read_settings()
    cfg['model'] = tier
    _write_settings(cfg)
    return jsonify({'ok': True, 'tier': tier})


