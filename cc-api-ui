      </div>
      <div class="hint-text">Quick actions write to settings.json immediately, independent of the active profile.</div>
    </div>`;
}

async function switchProfile(name) {
  const r = await fetch('/api/switch/' + encodeURIComponent(name), {method:'POST'});
  const d = await r.json();
  if (d.ok) { toast(`Switched to '${name}'`); await load(); }
  else toast(d.error || 'Error switching profile', true);
}

async function deleteProfile(name) {
  if (!confirm(`Delete profile '${name}'?`)) return;
  const r = await fetch('/api/profiles/' + encodeURIComponent(name), {method:'DELETE'});
  const d = await r.json();
  if (d.ok) {
    toast(`Deleted '${name}'`);
    selected = null;
    await load();
  } else toast(d.error || 'Error', true);
}

async function setModel() {
  const model = document.getElementById('qa-model').value.trim();
  if (!model) { toast('Enter a model name', true); return; }
  const r = await fetch('/api/model', {method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({model})});
  const d = await r.json();
  d.ok ? toast('Model set to: ' + model) : toast(d.error || 'Error', true);
}

async function clearModel() {
  const r = await fetch('/api/model', {method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({clear:true})});
  const d = await r.json();
  d.ok ? toast('Model cleared') : toast(d.error || 'Error', true);
}

async function setTier() {
  const tier = document.getElementById('qa-tier').value;
  const r = await fetch('/api/tier', {method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({tier})});
  const d = await r.json();
  d.ok ? toast('Tier set to: ' + tier) : toast(d.error || 'Error', true);
}

// ── Modal ────────────────────────────────────────────────────────────────────

function openModal(profileName) {
  editing = profileName || null;
  document.getElementById('modal-title').textContent = editing ? 'Edit Profile — ' + editing : 'Add Profile';
  document.getElementById('modal-submit').textContent = editing ? 'Save Changes' : 'Add Profile';
  const nameGroup = document.getElementById('name-group');

  if (editing) {
    const p = profiles.find(x => x.name === editing);
    nameGroup.style.display = 'none';
    document.getElementById('f-api-key').value = p.api_key || '';
    document.getElementById('f-base-url').value = p.base_url || '';
    document.getElementById('f-model').value = p.model || '';
    document.getElementById('f-tier').value = p.tier || '';
    document.getElementById('f-haiku').value = p.default_haiku || '';
    document.getElementById('f-sonnet').value = p.default_sonnet || '';
    document.getElementById('f-opus').value = p.default_opus || '';
  } else {
    nameGroup.style.display = '';
    document.getElementById('profile-form').reset();
  }
  document.getElementById('overlay').classList.remove('hidden');
  (editing ? document.getElementById('f-api-key') : document.getElementById('f-name')).focus();
}

function closeModal() {
  document.getElementById('overlay').classList.add('hidden');
  editing = null;
}

function overlayClick(e) {
  if (e.target === document.getElementById('overlay')) closeModal();
}

async function submitProfile(e) {
  e.preventDefault();
  const payload = {
    api_key: document.getElementById('f-api-key').value.trim(),
    base_url: document.getElementById('f-base-url').value.trim(),
    model: document.getElementById('f-model').value.trim(),
    tier: document.getElementById('f-tier').value,
    default_haiku: document.getElementById('f-haiku').value.trim(),
