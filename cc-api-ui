<script>
let profiles = [];
let selected = null;
let editing = null;

async function load() {
  const r = await fetch('/api/profiles');
  profiles = await r.json();
  renderSidebar();
  const active = profiles.find(p => p.active);
  const first = profiles[0];
  const target = selected ? profiles.find(p => p.name === selected) : null;
  if (target) renderContent();
  else if (active) selectProfile(active.name);
  else if (first) selectProfile(first.name);
  else renderContent();
}

function renderSidebar() {
  const el = document.getElementById('profile-list');
  if (!profiles.length) {
    el.innerHTML = '<div class="empty-state">No profiles yet</div>';
    return;
  }
  el.innerHTML = profiles.map(p => `
    <div class="profile-item ${p.active ? 'is-active' : ''} ${selected === p.name ? 'selected' : ''}"
         onclick="selectProfile('${esc(p.name)}')">
      <span class="dot">${p.active ? '●' : '○'}</span>
      <span class="pname">${h(p.name)}</span>
      ${p.active ? '<span class="active-badge">active</span>' : ''}
    </div>`).join('');
}

function selectProfile(name) {
  selected = name;
  renderSidebar();
  renderContent();
}

function renderContent() {
  const el = document.getElementById('content');
  const p = profiles.find(x => x.name === selected);
  if (!p) {
    el.innerHTML = profiles.length
      ? '<div class="no-selection">Select a profile to view details</div>'
      : '<div class="no-selection">No profiles yet — click + Add to create one</div>';
    return;
  }

  const hasTierModels = p.default_haiku || p.default_sonnet || p.default_opus;

  el.innerHTML = `
    <div class="card">
      <div class="card-title">
        Profile — ${h(p.name)}
        ${p.active ? '<span class="active-pill">active</span>' : ''}
      </div>
      <div class="info-grid">
        <span class="info-label">API Key</span>
        <span class="info-value">${h(p.api_key_masked)}</span>
        <span class="info-label">Base URL</span>
        <span class="info-value">${h(p.base_url)}</span>
        <span class="info-label">Model</span>
        <span class="info-value ${!p.model ? 'dim' : ''}">${h(p.model || '(provider default)')}</span>
        <span class="info-label">Tier</span>
        <span class="info-value ${!p.tier ? 'dim' : ''}">${h(p.tier || '(not set)')}</span>
        ${hasTierModels ? `
        <span class="info-label">Haiku model</span>
        <span class="info-value ${!p.default_haiku?'dim':''}">${h(p.default_haiku||'—')}</span>
        <span class="info-label">Sonnet model</span>
        <span class="info-value ${!p.default_sonnet?'dim':''}">${h(p.default_sonnet||'—')}</span>
        <span class="info-label">Opus model</span>
        <span class="info-value ${!p.default_opus?'dim':''}">${h(p.default_opus||'—')}</span>
        ` : ''}
      </div>
      <div class="btn-row">
        ${p.active
          ? '<button class="btn btn-secondary" disabled>Currently active</button>'
          : `<button class="btn btn-primary" onclick="switchProfile('${esc(p.name)}')">Switch to this</button>`}
        <button class="btn btn-secondary" onclick="openModal('${esc(p.name)}')">Edit</button>
        <button class="btn btn-danger" onclick="deleteProfile('${esc(p.name)}')">Delete</button>
      </div>
    </div>

    <div class="card">
      <div class="card-title">Quick Actions</div>
      <div class="quick-row">
        <span class="quick-label">Model</span>
        <input type="text" id="qa-model" placeholder="claude-sonnet-4-6" style="width:230px">
        <button class="btn btn-secondary" onclick="setModel()">Set</button>
        <button class="btn btn-secondary" onclick="clearModel()">Clear</button>
      </div>
      <div class="quick-row">
        <span class="quick-label">Tier</span>
        <select id="qa-tier" style="width:110px">
          <option value="sonnet">sonnet</option>
          <option value="opus">opus</option>
          <option value="haiku">haiku</option>
        </select>
